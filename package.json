  "scripts": {
    "docs:dev": "vitepress dev",
    "docs:clean": "node -e \"try{require('fs').rmSync('.vitepress/dist',{recursive:true,force:true})}catch(e){};try{require('fs').rmSync('.vitepress/cache',{recursive:true,force:true})}catch(e){};try{require('fs').unlinkSync('wjqf-doc.zip')}catch(e){}\"",
    "docs:build": "vitepress build && node scripts/zip.cjs",
    "docs:preview": "vitepress preview"
  },
  "devDependencies": {
    "vitepress": "^2.0.0-alpha.17"
  }
