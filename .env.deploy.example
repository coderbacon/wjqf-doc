# ==================== 部署服务器配置 ====================
# 复制此文件为 .env.deploy 并填写真实值
# .env.deploy 已在 .gitignore 中排除，不会提交到 Git

# Linux 服务器地址（IP 或域名）
DEPLOY_HOST=192.168.1.100

# SSH 登录用户名
DEPLOY_USER=root

# 服务器上的目标目录（绝对路径）
DEPLOY_PATH=/var/www/wjqf-doc

# SSH 端口（默认 22）
DEPLOY_PORT=22

# SSH 私钥路径（使用密钥免密登录）
# DEPLOY_KEY=C:/Users/DELL/.ssh/id_ed25519

# 部署前是否清空目标目录（默认 true，防止残留旧文件）
# 设为 false 则仅覆盖同名文件
# DEPLOY_CLEAN=true
